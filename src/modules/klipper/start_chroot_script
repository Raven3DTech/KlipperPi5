#!/bin/bash
# ============================================================
# RatOS PI5 â€” Klipper module install script
# Runs inside the chroot of the base image during build.
# ============================================================
set -ex

source /common.sh
install_cleanup_trap

# â”€â”€ Source module config â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Variables are automatically exported by CustomPiOS

# â”€â”€ System dependencies â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
apt-get update --allow-releaseinfo-change
apt-get install -y --no-install-recommends \
    python3-pip \
    python3-dev \
    python3-virtualenv \
    python3-numpy \
    python3-cffi \
    python3-greenlet \
    libffi-dev \
    build-essential \
    git \
    libncurses-dev \
    avrdude \
    gcc-avr \
    binutils-avr \
    avr-libc \
    stm32flash \
    dfu-util \
    libnewlib-arm-none-eabi \
    gcc-arm-none-eabi \
    binutils-arm-none-eabi \
    libusb-1.0-0

# â”€â”€ Clone Klipper â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
sudo -u pi git clone ${KLIPPER_REPO} ${KLIPPER_DIR}
cd ${KLIPPER_DIR}
sudo -u pi git checkout ${KLIPPER_BRANCH}

# â”€â”€ Create Python virtualenv â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
sudo -u pi python3 -m virtualenv -p python3 ${KLIPPER_VENV}
sudo -u pi ${KLIPPER_VENV}/bin/pip install --upgrade pip
sudo -u pi ${KLIPPER_VENV}/bin/pip install -r ${KLIPPER_DIR}/scripts/klippy-requirements.txt

# â”€â”€ Create printer_data directory structure â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
sudo -u pi mkdir -p \
    /home/pi/printer_data/config \
    /home/pi/printer_data/logs \
    /home/pi/printer_data/gcodes \
    /home/pi/printer_data/systemd \
    /home/pi/printer_data/comms \
    /home/pi/printer_data/certs \
    /home/pi/printer_data/backup

# â”€â”€ Copy default printer.cfg â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
sudo -u pi cp /filesystem/home/pi/printer_data/config/printer.cfg \
              /home/pi/printer_data/config/printer.cfg

# â”€â”€ Install systemd service â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
cp /filesystem/etc/systemd/system/klipper.service /etc/systemd/system/klipper.service

systemctl_if_exists enable klipper

# â”€â”€ Serial / USB permissions â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
usermod -a -G tty,dialout,plugdev pi

# â”€â”€ udev rules for DFU / STM32 flashing â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
cat > /etc/udev/rules.d/49-ratos.rules << 'EOF'
# STM32 DFU
SUBSYSTEMS=="usb", ATTRS{idVendor}=="0483", ATTRS{idProduct}=="df11", MODE="0666", GROUP="plugdev"
# RP2040 (Raspberry Pi Pico)
SUBSYSTEMS=="usb", ATTRS{idVendor}=="2e8a", ATTRS{idProduct}=="0003", MODE="0666", GROUP="plugdev"
# Generic USB-serial for flashing
SUBSYSTEMS=="usb-serial", MODE="0660", GROUP="dialout"
EOF

echo "âœ… Klipper module installed"
