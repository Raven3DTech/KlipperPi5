#!/bin/bash
# ============================================================
# R3DTOS PI5 — prebase: refresh apt lists before CustomPiOS `base`
# The `base` module runs `apt-get install --only-upgrade userconf-pi` without
# its own `apt-get update`; on fresh Pi OS (e.g. trixie) that can fail CI builds.
# ============================================================
set -ex

source /common.sh
install_cleanup_trap

apt-get update --allow-releaseinfo-change

echo "✅ prebase: apt lists ready for base module"
