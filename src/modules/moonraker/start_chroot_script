#!/bin/bash
# ============================================================
# RatOS PI5 â€” Moonraker module install script
# ============================================================
set -ex

source /common.sh
install_cleanup_trap

# Variables are automatically exported by CustomPiOS

# â”€â”€ System dependencies â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
apt-get update --allow-releaseinfo-change
apt-get install -y --no-install-recommends \
    python3-virtualenv \
    python3-dev \
    libopenjp2-7 \
    libsodium-dev \
    curl \
    packagekit \
    wireless-tools \
    iw \
    rfkill \
    liblmdb-dev \
    libssl-dev \
    libjpeg-dev \
    zlib1g-dev \
    haproxy

# â”€â”€ Clone Moonraker â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
sudo -u pi git clone ${MOONRAKER_REPO} ${MOONRAKER_DIR}
cd ${MOONRAKER_DIR}
sudo -u pi git checkout ${MOONRAKER_BRANCH}

# â”€â”€ Create Python virtualenv â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
sudo -u pi python3 -m virtualenv -p python3 ${MOONRAKER_VENV}
sudo -u pi ${MOONRAKER_VENV}/bin/pip install --upgrade pip
sudo -u pi ${MOONRAKER_VENV}/bin/pip install -r ${MOONRAKER_DIR}/scripts/moonraker-requirements.txt

# â”€â”€ Install moonraker.conf â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
cp /filesystem/home/pi/printer_data/config/moonraker.conf \
   /home/pi/printer_data/config/moonraker.conf
chown pi:pi /home/pi/printer_data/config/moonraker.conf

# â”€â”€ PolicyKit rules for PackageKit / power actions â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
cat > /etc/polkit-1/rules.d/moonraker.rules << 'EOF'
polkit.addRule(function(action, subject) {
    if ((action.id == "org.freedesktop.systemd1.manage-units" ||
         action.id == "org.freedesktop.login1.power-off" ||
         action.id == "org.freedesktop.login1.reboot") &&
        subject.user == "pi") {
        return polkit.Result.YES;
    }
});
EOF

# â”€â”€ Moonraker systemd service â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
cp /filesystem/etc/systemd/system/moonraker.service /etc/systemd/system/moonraker.service
systemctl_if_exists enable moonraker

echo "âœ… Moonraker module installed"
