#!/bin/bash
# ============================================================
# RatOS PI5 â€” Mainsail module install script
# ============================================================
set -ex

source /common.sh
install_cleanup_trap

# Variables are automatically exported by CustomPiOS

# â”€â”€ System dependencies â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
apt-get update --allow-releaseinfo-change
apt-get install -y --no-install-recommends \
    nginx \
    unzip \
    curl \
    wget

# â”€â”€ Download latest Mainsail release â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
MAINSAIL_RELEASE_URL=$(curl -sI \
    https://github.com/mainsail-crew/mainsail/releases/latest \
    | grep -i '^location:' \
    | awk '{print $2}' \
    | tr -d '\r')

MAINSAIL_VERSION=$(echo "${MAINSAIL_RELEASE_URL}" | awk -F'/tag/' '{print $2}')

echo "Installing Mainsail ${MAINSAIL_VERSION}"

wget -q \
    "https://github.com/mainsail-crew/mainsail/releases/download/${MAINSAIL_VERSION}/mainsail.zip" \
    -O /tmp/mainsail.zip

mkdir -p ${MAINSAIL_WEBROOT}
unzip -q /tmp/mainsail.zip -d ${MAINSAIL_WEBROOT}
rm /tmp/mainsail.zip

# â”€â”€ Also keep a copy in pi home for update_manager tracking â”€â”€
sudo -u pi mkdir -p ${MAINSAIL_DIR}
sudo -u pi cp -r ${MAINSAIL_WEBROOT}/. ${MAINSAIL_DIR}/

# â”€â”€ Symlink so nginx serves from the tracked directory â”€â”€â”€â”€â”€â”€â”€â”€
rm -rf ${MAINSAIL_WEBROOT}
ln -s ${MAINSAIL_DIR} ${MAINSAIL_WEBROOT}

# â”€â”€ Mainsail config.json â€” Moonraker via nginx on same host (:80) â”€
# Hard-coding hostname:7125 breaks when the UI is opened at http://<IP>/ (cross-origin â†’ Moonraker 401/CORS; UI can show 500).
cat > ${MAINSAIL_DIR}/config.json << 'EOF'
{
    "instancesDB": "moonraker",
    "instances": [
        {
            "name": "RatOS",
            "hostname": "",
            "port": 80,
            "path": "/"
        }
    ],
    "customNavigation": [
        {
            "title": "Configurator",
            "href": "/configure/",
            "target": "_self",
            "position": 82
        }
    ]
}
EOF

# â”€â”€ nginx config â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
cp /filesystem/etc/nginx/sites-available/mainsail \
   /etc/nginx/sites-available/mainsail

rm -f /etc/nginx/sites-enabled/default
ln -sf /etc/nginx/sites-available/mainsail /etc/nginx/sites-enabled/mainsail

# Lay down filesystem/root (helper script, NM dispatcher, nginx drop-in) â€” same pattern as hotspot.
unpack /filesystem/root /

# â”€â”€ Root URL: Ethernet â†’ Mainsail, no cable â†’ Configurator â”€â”€â”€
mkdir -p /var/lib/ratos
chmod +x /usr/local/bin/ratos-update-nginx-root.sh
/usr/local/bin/ratos-update-nginx-root.sh
systemctl daemon-reload || true

# â”€â”€ Verify nginx config â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
nginx -t

systemctl_if_exists enable nginx

echo "âœ… Mainsail module installed â€” version ${MAINSAIL_VERSION}"
