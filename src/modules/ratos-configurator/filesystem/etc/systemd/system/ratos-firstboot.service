[Unit]
Description=RatOS PI5 First Boot Setup
After=network.target
ConditionPathExists=/home/pi/scripts/ratos-firstboot.sh

[Service]
Type=oneshot
ExecStart=/bin/bash /home/pi/scripts/ratos-firstboot.sh
RemainAfterExit=yes
StandardOutput=journal
StandardError=journal
SyslogIdentifier=ratos-firstboot

[Install]
WantedBy=multi-user.target
